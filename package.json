{
  "name": "ctools",
  "version": "0.1.0",
  "description": "Herramienta de gestión interna para tiendas",
  "main": "dist/electron/main.js",
  "private": true,
  "scripts": {
    "dev:frontend": "cd frontend && vite",
    "dev:server": "tsx watch server/index.ts",
    "predev": "npx electron-rebuild -f -w better-sqlite3 -w argon2",
    "dev": "electron-vite dev",
    "build:frontend": "cd frontend && vite build",
    "build:server": "esbuild server/index.ts --bundle --platform=node --target=node20 --outfile=dist/server/index.js --external:better-sqlite3 --external:argon2 && rm -rf dist/server/migrations && cp -r server/db/migrations dist/server/migrations",
    "build:electron": "electron-vite build",
    "build:electron:windows": "npm run build && npx electron-builder --win --x64",
    "build": "npm run build:frontend && npm run build:server && npm run build:electron",
    "package": "npm run build && electron-builder",
    "pretest": "npm rebuild better-sqlite3 argon2",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@hono/node-server": "^2.0.3",
    "@hono/zod-validator": "^0.8.0",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "electron-updater": "^6.8.3",
    "hono": "^4.12.22",
    "pino": "^10.3.1",
    "svelte-spa-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.10",
    "electron": "^41.7.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "esbuild": "^0.28.0",
    "svelte": "^5.55.9",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
